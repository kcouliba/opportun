{
  "name": "opportun",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:rust": "cargo clippy --manifest-path src-tauri/Cargo.toml -- -D warnings",
    "type-check": "tsc --noEmit",
    "check": "npm run lint && npm run type-check && npm run lint:rust",
    "test": "vitest run",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test:all": "npm run test && npm run test:rust",
    "test:watch": "vitest",
    "audit": "npm audit && cargo audit --file src-tauri/Cargo.lock",
    "tauri": "tauri",
    "release": "bash scripts/bump-version.sh"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@react-pdf/renderer": "^4.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.18",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4",
    "clsx": "^2.1.1",
    "eslint": "^9.36.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^3"
  }
}
