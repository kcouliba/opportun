generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// PROFILE - Foundation for filtering and matching
// =============================================================================

model Profile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity
  name            String
  title           String?  // "Senior Fullstack Developer"
  yearsExperience Int?

  // Legal & Financial
  legalStructure String?  // SASU, EURL, etc.
  minimumTJM     Int?     // Won't consider below this
  targetTJM      Int?     // Ideal rate

  // Location preferences
  preferredLocations String?  // JSON array: ["Remote", "Paris", "Hybrid"]
  maxCommuteDays     Int?     // Days/week willing to commute

  // Skills (JSON arrays for flexibility in MVP)
  technologies String?  // JSON array: ["React", "Node.js", "PostgreSQL"]
  domains      String?  // JSON array: ["Fintech", "E-commerce", "SaaS"]

  // Deal-breakers (JSON arrays)
  blacklistedClients String?  // JSON array: companies to avoid
  blacklistedDomains String?  // JSON array: industries to avoid

  // Relations
  missions Mission[]
  leads    Lead[]
}

// =============================================================================
// MISSION - Current/past work
// =============================================================================

model Mission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Core info
  client      String
  title       String
  description String?

  // Timeline
  startDate DateTime
  endDate   DateTime?  // null = ongoing

  // Financial
  rate        Int      // TJM in euros
  daysPerWeek Float    @default(5)

  // Status
  status String @default("active")  // active, completed, cancelled

  // Relations
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

// =============================================================================
// LEAD - Pipeline entries
// =============================================================================

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Source info
  source    String   // platform, recruiter, referral, direct
  sourceUrl String?  // Link to original posting

  // Opportunity details
  client      String
  title       String
  description String?

  // Requirements (for matching)
  requiredTechnologies String?  // JSON array
  requiredDomains      String?  // JSON array
  location             String?
  remotePolicy         String?  // remote, hybrid, onsite

  // Financial
  offeredRate      Int?      // If disclosed
  estimatedRevenue Int?      // Calculated: rate * estimated days

  // Timeline
  estimatedStartDate DateTime?
  estimatedDuration  Int?      // in months

  // Pipeline
  stage String @default("lead")  // lead, qualified, negotiating, won, lost

  // Scoring (computed)
  matchScore   Int?      // 0-100 match against profile
  autoFiltered Boolean   @default(false)  // true if below thresholds

  // Tracking
  notes       String?
  contactName String?
  contactInfo String?
  nextAction  String?
  nextActionDate DateTime?

  // Relations
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  // Generated documents
  documents Document[]
}

// =============================================================================
// DOCUMENT - Generated cover letters, key questions, etc.
// =============================================================================

model Document {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type    String  // cover_letter, key_questions, cv, proposal
  content String  // The generated content
  version Int     @default(1)

  // Relations
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
}
